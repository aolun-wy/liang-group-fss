# THIS DEFAULT PROGRAM INITIALIZE GEANT4,
# AND SHOOTS 1000 PARTICLES DEFINED IN THE SOURCE FILES

# Initialization of Geant4
/run/initialize

# === Non-Tracking ===
# Shoot Beams of Particle (minor)
#/tracking/verbose 0
#/run/beamOn 1000

# Shoot Beams of Particle (FSS analysis)
/tracking/verbose 0
/run/beamOn 100000

# === Tracking ===
#/tracking/verbose 1
#/run/beamOn 10000